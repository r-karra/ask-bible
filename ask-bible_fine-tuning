ell_type":"markdown","source":"# 📈 Step 3:— Phase 1: Continual Pre-Training (CPT)\nNow we load your base model unsloth/gemma-4-e2b in 4-bit precision to maximize available memory space, inject standard tracking adapters (LoRA), and feed it the raw text lines out of kjv_raw_pretrain.jsonl.","metadata":{}},{"cell_type":"code","source":"# DO NOT run any other pip installs here if you already ran the one above\nimport os\n# Set this BEFORE any other imports to prevent internal library collisions\nos.environ[\"NO_CACHE\"] = \"1\"\nfrom unsloth import FastLanguageModel\nfrom datasets import load_dataset\nfrom trl import SFTTrainer, SFTConfig\nimport torch\n\n# 1. Load the pre-quantized base generalist model window\nmax_seq_length = 2048\ndtype = None # Auto-detect precision matching the runtime GPU\nload_in_4bit = True # Maintain low memory configurations\n\nmodel, tokenizer = FastLanguageModel.from_pretrained(\n    model_name = \"unsloth/gemma-4-e2b\",\n    max_seq_length = max_seq_length,\n    dtype = dtype,\n    load_in_4bit = load_in_4bit,\n)\n\n# 2. Setup LoRA adapter target projection matrices\nmodel = FastLanguageModel.get_peft_model(\n    model,\n    r = 16,\n    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n    lora_alpha = 16,\n    lora_dropout = 0,\n    bias = \"none\",\n    use_gradient_checkpointing = \"unsloth\",\n    max_seq_length = max_seq_length,\n)\n\n# 3. Stream data from the file generated in your first cell\ndataset = load_dataset(\"json\", data_files=\"/kaggle/working/kjv_raw_pretrain.jsonl\", split=\"train\")\n\n# Continuous pre-training simply looks for sequence complete markers\ndataset = dataset.map(lambda x: { \"text\" : [t + tokenizer.eos_token for t in x[\"text\"]] }, batched = True)\n\n# 4. Initialize SFTTrainer for causal language modelling loss metrics\ntrainer = SFTTrainer(\n    model = model,\n    tokenizer = tokenizer,\n    train_dataset = dataset,\n    args = SFTConfig(\n        dataset_text_field = \"text\",\n        max_seq_length = max_seq_length,\n        per_device_train_batch_size = 2,\n        gradient_accumulation_steps = 4, # Simulates an effective batch size of 8 tokens\n        max_steps = 60, # Keep steps compact to adapt tone without complete catastrophic forgetting\n        learning_rate = 2e-4,\n        fp16 = not torch.cuda.is_bf16_supported(),\n        bf16 = torch.cuda.is_bf16_supported(),\n        logging_steps = 1,\n        output_dir = \"pretrain_outputs\",\n        save_strategy = \"no\" # Disable checkpoints to prevent memory overhead surges\n    ),\n)\n\nprint(\"Starting Phase 1 Training Loop...\")\ntrainer_stats = trainer.train()\nprint(\"🎉 Phase 1 Complete! The model's active adapter weights are adapted to 17th-century English.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T12:32:07.960041Z","iopub.execute_input":"2026-06-25T12:32:07.961164Z","iopub.status.idle":"2026-06-25T12:41:00.521464Z","shell.execute_reply.started":"2026-06-25T12:32:07.961118Z","shell.execute_reply":"2026-06-25T12:41:00.520332Z"}},"outputs":[{"name":"stderr","text":"/usr/local/lib/python3.12/dist-packages/unsloth/__init__.py:153: UserWarning: WARNING: Unsloth should be imported before [transformers] to ensure all optimizations are applied. Your code may run slower or encounter memory issues without these optimizations.\n\nPlease restructure your imports with 'import unsloth' at the top of your file.\n  from ._gpu_init import *\n","output_type":"stream"},{"name":"stdout","text":"🦥 Unsloth: Will patch your computer to enable 2x faster free finetuning.\n🦥 Unsloth Zoo will now patch everything to make training faster!\n==((====))==  Unsloth 2026.6.9: Fast Gemma4 patching. Transformers: 5.5.0.\n   \\\\   /|    Tesla T4. Num GPUs = 2. Max memory: 14.562 GB. Platform: Linux.\nO^O/ \\_/ \\    Torch: 2.10.0+cu128. CUDA: 7.5. CUDA Toolkit: 12.8. Triton: 3.6.0\n\\        /    Bfloat16 = FALSE. FA [Xformers = 0.0.35. 
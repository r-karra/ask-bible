nguageModel.get_peft_model(\n    model,\n    r = 16,\n    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n    lora_alpha = 16,\n    lora_dropout = 0,\n    bias = \"none\",\n    use_gradient_checkpointing = \"unsloth\",\n    max_seq_length = max_seq_length,\n)\n\n# 3. Stream data from the file generated in your first cell\ndataset = load_dataset(\"json\", data_files=\"/kaggle/working/kjv_raw_pretrain.jsonl\", split=\"train\")\n\n# Continuous pre-training simply looks for sequence complete markers\ndataset = dataset.map(lambda x: { \"text\" : [t + tokenizer.eos_token for t in x[\"text\"]] }, batched = True)\n\n# 4. Initialize SFTTrainer for causal language modelling loss metrics\ntrainer = SFTTrainer(\n    model = model,\n    tokenizer = tokenizer,\n    train_dataset = dataset,\n    args = SFTConfig(\n        dataset_text_field = \"text\",\n        max_seq_length = max_seq_length,\n        per_device_train_batch_size = 2,\n        gradient_accumulation_steps = 4, # Simulates an effective batch size of 8 tokens\n        max_steps = 60, # Keep steps compact to adapt tone without complete catastrophic forgetting\n        learning_rate = 2e-4,\n        fp16 = not torch.cuda.is_bf16_supported(),\n        bf16 = torch.cuda.is_bf16_supported(),\n        logging_steps = 1,\n        output_dir = \"pretrain_outputs\",\n        save_strategy = \"no\" # Disable checkpoints to prevent memory overhead surges\n    ),\n)\n\nprint(\"Starting Phase 1 Training Loop...\")\ntrainer_stats = trainer.train()\nprint(\"🎉 Phase 1 Complete! The model's active adapter weights are adapted to 17th-century English.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-20T06:26:35.608906Z","iopub.execute_input":"2026-06-20T06:26:35.610053Z","iopub.status.idle":"2026-06-20T06:35:46.544012Z","shell.execute_reply.started":"2026-06-20T06:26:35.609968Z","shell.execute_reply":"2026-06-20T06:35:46.543262Z"}},"outputs":[{"name"
ut sandbox:","metadata":{}},{"cell_type":"code","source":"import transformers; print(transformers.__version__)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T12:30:12.258491Z","iopub.execute_input":"2026-06-25T12:30:12.258926Z","iopub.status.idle":"2026-06-25T12:30:15.690760Z","shell.execute_reply.started":"2026-06-25T12:30:12.258898Z","shell.execute_reply":"2026-06-25T12:30:15.689918Z"}},"outputs":[{"name":"stdout","text":"5.5.0\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"import json\nimport os\nimport random\n\ninput_root = \"/kaggle/input\"\ninput_json_path = None\n\n# 1. Target 'kjv_bible_dataset.json' path dynamically\nfor root, dirs, files in os.walk(input_root):\n    for filename in files:\n        if filename == \"kjv_bible_dataset.json\":\n            input_json_path = os.path.join(root, filename)\n            print(f\"🎯 Target Found -> {input_json_path}\")\n            break\n    if input_json_path:\n        break\n\nif not input_json_path:\n    raise FileNotFoundError(\"❌ Could not find 'kjv_bible_dataset.json'. Ensure the dataset input is attached.\")\n\n# Archaic substitution dictionary for preference mapping (DPO)\narchaic_to_modern_slang = {\n    \"God\": \"the universe\", \"LORD\": \"the big boss\", \"heaven\": \"sky\", \"earth\": \"dirt\",\n    \"shepherd\": \"manager\", \"shall not want\": \"am totally fine\", \"created\": \"spawned\",\n    \"unto\": \"to\", \"thee\": \"you\", \"thou\": \"you\", \"thy\": \"your\", \"shalt\": \"will\"\n}\n\ndef generate_rejected_text(text):\n    words = text.split()\n    modified_words = [archaic_to_modern_slang.get(w.strip(\".,;:?!\"), w) for w in words]\n    return \" \".join(modified_words) + \" i guess, idk lol.\"\n\nraw_dataset = []\ninstruction_dataset = []\npreference_dataset = []\n\n# 2. Open and deserialize the dataset\nwith open(input_json_path, 'r', encoding='utf-8') as f:\n    bible_data = json.load(f)\n\n# If it's wrapped in an outer dictionary node, unbox it to get the list\nif isinstance(bible_data, dict):\n    for key, val in bible_data.items():\n        if isinstance(val, list):\n            bible_data = val\n            break\n\nprint(f\"Traversing {len(bible_data)} top-level structural elements...\")\n\n# 3. Deep Extraction Recursive Loop\nfor entry_idx, entry in enumerate(bible_data):\n    if not isinstance(entry, dict):\n        continue\n    \n    # Check if this object holds a nested list of elements/verses\n    nested_list = None\n    for k, v in entry.items():\n        if isinstance(v, list):\n            nested_list = v\n            break\n            \n    # Context extraction fallback references\n    parent_book = entry.get(\"book\") or entry.get(\"Book\") or \"Scripture\"\n    parent_chapter = entry.get(\"chapter\") or entry.get(\"Chapter\") or \"1\"\n\n    # Scenario A: The object contains an internal collection array\n    if nested_list is not None:\n        for inner_idx, item in enumerate(nested_list):\n            if isinstance(item, dict):\n                clean_text = str(item.get(\"text\") or item.get(\"Text\") or item.get(\"verse\") or \"\").strip()\n                book_name = str(item.get(\"book\") or item.get(\"Book\") or parent_book).strip()\n                chapter_num = str(item.get(\"chapter\") or item.get(\"Chapter\") or parent_chapter).strip()\n                verse_num = str(item.get(\"verse\") or item.get(\"Verse\") or f\"{inner_idx+1}\").strip()\n            else:\n                clean_text = str(item).strip()\n                book_name = parent_book\n                chapter_num = parent_chapter\n                verse_num = f\"{inner_idx+1}\"\n                \n            if not clean_text or len(clean_text) < 3:\n                continue\n                \n            reference = f\"{book_name} {chapter_num}:{verse_num}\"\n            \n            raw_dataset.append({\"text\": f\"{reference} - {clean_text}\"})\n            \n            instruction_templates = [\n                f\"Provide the scripture for {reference}.\",\n                f\"What is written in the book of {book_name}, chapter {chapter_num}, verse {verse_num}?\",\n                f\"Quote {reference} from the King James Bible.\"\n            ]\n            instruction_dataset.append({\"instruction\": random.choice(instruction_templates), \"input\": \"\", \"output\": clean_text})\n            preference_dataset.append({\"instruction\": f\"Recite {reference} exactly as written in the historical King James Version.\", \"chosen\": clean_text, \"rejected\": generate_rejected_text(clean_text)})\n\n    # Scenario B: The top-level item itself is a single flat verse entry\n    else:\n        clean_text = str(entry.get(\"text\") or entry.get(\"Text\") or \"\").strip()\n        if not clean_text or len(clean_text) < 3:\n            continue\n            \n        book_name = str(entry.get(\"book\") or entry.get(\"Book\") or \"Scripture\").strip()\n        chapter_num = str(entry.get(\"chapter\") or entry.get(\"Chapter\") or \"1\").strip()\n        verse_num = str(entry.get(\"verse\") or entry.get(\"Verse\") or f\"{entry_idx+1}\").strip()\n        \n        reference = f\"{book_name} {chapter_num}:{verse_num}\"\n        \n        raw_dataset.append({\"text\": f\"{reference} - {clean_text}\"})\n        instruction_dataset.append({\"instruction\": f\"Quote {reference} from the King James Bible.\", \"input\": \"\", \"output\": clean_text})\n        preference_dataset.append({\"instruction\": f\"Recite {reference} exactly as written in the historical King James Version.\", \"chosen\": clean_text, \"rejected\": generate_rejected_text(clean_text)})\n\n# 4. Save and verify files on disk\ndef save_local_jsonl(data_list, filename):\n    output_path = os.path.join(\"/kaggle/working\", filename)\n    with open(output_path, 'w', encoding='utf-8', buffering=1) as out_f:\n        for node in data_list:\n            out_f.write(json.dumps(node, ensure_ascii=False) + '\\n')\n        out_f.flush()\n        os.fsync(out_f.fileno())\n    print(f\"Generated -> {filename} | Total Records: {len(data_list):,} | Size: {os.path.getsize(output_path):,} bytes\")\n\nprint(\"\\n--- Saving files to Kaggle workspace ---\")\nsave_local_jsonl(raw_dataset, \"kjv_raw_pretrain.jsonl\")\nsave_local_jsonl(instruction_dataset, \"kjv_instruction_sft.jsonl\")\nsave_local_jsonl(preference_dataset, \"kjv_preference_dpo.jsonl\")\n\nprint(\"\\n🎉 Data Engineering Complete! Check your sizes below.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T12:30:18.993439Z","iopub.execute_input":"2026-06-25T12:30:18.993829Z","iopub.status.idle":"2026-06-25T12:30:19.275253Z","shell.execute_reply.started":"2026-06-25T12:30:18.993796Z","shell.execute_reply":"2026-06-25T12:30:19.274499Z"}},"outputs":[{"name":"stdout","text":"🎯 Target Found -> /kaggle/input/datasets/rajeshkumarkarra/cleaned-kjv-bible-for-llms/kjv_bible_dataset.json\nTraversing 242 top-level structural elements...\n\n--- Saving files to Kaggle workspace ---\nGenerated -> kjv_raw_pretrain.jsonl | Total Records: 1,234 | Size: 1,675,552 bytes\nGenerated -> kjv_instruction_sft.jsonl | Total Records: 1,234 | Size: 1,758,758 bytes\nGenerated -> kjv_preference_dpo.jsonl | Total Records: 1,234 | Size: 3,481,095 bytes\n\n🎉 Data Engineering Complete! Check your sizes below.\n","output_type":"stream"}],"execution_count":2},{"cell_type":"code","source":"!head -n 2 /kaggle/working/kjv_raw_pretrain.jsonl","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T12:30:32.517398Z","iopub.execute_input":"2026-06-25T12:30:32.517749Z","iopub.status.idle":"2026-06-25T12:30:32.640698Z","shell.execute_reply.started":"2026-06-25T12:30:32.517720Z","shell.execute_reply":"2026-06-25T12:30:32.639371Z"},"collapsed":true,"jupyter":{"outputs_hidden":true}},"outputs":[{"name":"stdout","text":"{\"text\": \"Genesis 1:1 - ['In the beginning God created the heaven and the earth.', 'And the earth was without form, and vo
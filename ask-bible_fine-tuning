n that describes a task. Write a response that appropriately completes the request.\n\n### Instruction:\n{}\n\n### Response:\n{}\"\"\"\n\ndef format_sft(examples):\n    # Ensure this matches the keys you created in Cell 1\n    texts = [prompt_format.format(i, o) + tokenizer.eos_token for i, o in zip(examples[\"instruction\"], examples[\"output\"])]\n    return { \"text\" : texts }\n\nsft_dataset = sft_dataset.map(format_sft, batched = True)\n\n# 4. Initialize Trainer\nsft_trainer = SFTTrainer(\n    model = model,\n    tokenizer = tokenizer,\n    train_dataset = sft_dataset,\n    args = SFTConfig(\n        dataset_text_field = \"text\",\n        max_seq_length = max_seq_length,\n        per_device_train_batch_size = 2,\n        gradient_accumulation_steps = 4,\n        max_steps = 60,\n        learning_rate = 2e-5,\n        fp16 = not torch.cuda.is_bf16_supported(),\n        bf16 = torch.cuda.is_bf16_supported(),\n        logging_steps = 1,\n        output_dir = \"sft_outputs\",\n        save_strategy = \"no\"\n    ),\n)\nsft_trainer.train()\nprint(\"Phase 2 (SFT) complete!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-20T06:40:48.734120Z","iopub.execute_input":"2026-06-20T06:40:48.734493Z","iopub.status.idle":"2026-06-20T06:47:44.539179Z","shell.execute_reply.started":"2026-06-20T06:40:48.734449Z","shell.execute_reply":"2026-06-20T06:47:44.538012Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Generating train split: 0 examples [00:00, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d000a3c7241a436eb5695e327686c1b6"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/1234 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"b88e0b1df0ae406ba1cb021b962d3467"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Unsloth: Tokenizing [\"text\"] (num
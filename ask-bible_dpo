AM saver)\n    max_prompt_length=128,\n    max_length=256,\n\n    max_steps=30,\n    logging_steps=1,\n\n    fp16=True,\n    bf16=False,\n\n    gradient_checkpointing=False,\n\n    optim=\"paged_adamw_8bit\",\n\n    save_strategy=\"no\",\n    report_to=\"none\",\n)\n\n\n\n# --------------------------------------------------\n# Trainer\n# --------------------------------------------------\ntrainer = DPOTrainer(\n    model=model,\n    ref_model=None,\n    tokenizer=tokenizer,\n    train_dataset=dpo_dataset,\n    args=dpo_config,\n)\n\n# --------------------------------------------------\n# Train\n# --------------------------------------------------\ntrainer.train()\n\n# --------------------------------------------------\n# Save LoRA Adapter\n# --------------------------------------------------\nadapter_path = \"/kaggle/working/final_bible_aligned_adapter\"\n\nmodel.save_pretrained(adapter_path)\ntokenizer.save_pretrained(adapter_path)\n\n# --------------------------------------------------\n# Save Merged 16-bit Model\n# --------------------------------------------------\nmerged_path = \"/kaggle/working/gemma-4-bible-dpo-merged\"\n\nmodel.save_pretrained_merged(\n    merged_path,\n    tokenizer,\n    save_method=\"merged_16bit\",\n)\n\n# --------------------------------------------------\n# Push LoRA Adapter\n# --------------------------------------------------\nmodel.push_to_hub(\n    \"r-karra/gemma-4-bible-dpo\",\n    token=hf_token,\n)\n\ntokenizer.push_to_hub(\n    \"r-karra/gemma-4-bible-dpo\",\n    token=hf_token,\n)\n\n# --------------------------------------------------\n# Push Merged 16-bit Model\n# --------------------------------------------------\nmodel.push_to_hub_merged(\n    \"r-karra/gemma-4-bible-dpo-merged\",\n    tokenizer,\n    save_method=\"merged_16bit\",\n    token=hf_token,\n)\n\nprint(\"🎉 DPO Training Complete!\")\nprint(f\"LoRA Adapter : {adapter_path}\")\nprint(f\"Merged 16-bit Model : {merged_path}\")","metadata":{"trusted":true,"execution"
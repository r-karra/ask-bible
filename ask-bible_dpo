    "from unsloth import FastLanguageModel\n",
    "import torch\n",
    "\n",
    "# Load the base model\n",
    "model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name = \"unsloth/gemma-4-e2b\",\n",
    "    max_seq_length = 512, # Low sequence length for DPO stability\n",
    "    dtype = None,\n",
    "    load_in_4bit = True,\n",
    ")\n",
    "\n",
    "# Add your adapter from the Hub\n",
    "model = FastLanguageModel.get_peft_model(\n",
    "    model,\n",
    "    r = 16,\n",
    "    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n",
    "    lora_alpha = 16,\n",
    "    lora_dropout = 0,\n",
    "    bias = \"none\",\n",
    "    use_gradient_checkpointing = \"unsloth\",\n",
    ")\n",
    "\n",
    "# Load your SFT-trained weights\n",
    "model.load_adapter(\"r-karra/gemma-4-bible-sft\", adapter_name=\"bible_sft\")"
   ]
